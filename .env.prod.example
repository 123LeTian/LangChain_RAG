# ===================================================================
# LangChain RAG 生产环境配置模板
# ===================================================================
# 使用方法: 复制此文件为 .env.prod 并填入真实值
#   cp .env.prod.example .env.prod
# 然后设置环境变量 APP_ENV=prod 启动应用
# ===================================================================

# ==================== 0. 应用环境 ====================
APP_ENV=prod

# ==================== 1. 模型提供商选择 ====================
# 可选值: deepseek | openai | qwen | glm | moonshot
LLM_PROVIDER=deepseek

# ==================== 2. DeepSeek 配置 ====================
DEEPSEEK_API_KEY=your-prod-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=8192

# ==================== 3. OpenAI 配置 (备用) ====================
OPENAI_API_KEY=your-prod-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o
OPENAI_TEMPERATURE=0.5
OPENAI_MAX_TOKENS=8192

# ==================== 4. 通义千问 Qwen 配置 (备用) ====================
QWEN_API_KEY=your-prod-qwen-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_NAME=qwen-plus
QWEN_TEMPERATURE=0.5
QWEN_MAX_TOKENS=8192

# ==================== 5. 智谱 GLM 配置 (备用) ====================
GLM_API_KEY=your-prod-glm-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL_NAME=glm-4
GLM_TEMPERATURE=0.5
GLM_MAX_TOKENS=8192

# ==================== 6. Moonshot 配置 (备用) ====================
MOONSHOT_API_KEY=your-prod-moonshot-key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL_NAME=moonshot-v1-32k
MOONSHOT_TEMPERATURE=0.5
MOONSHOT_MAX_TOKENS=8192

# ==================== 7. 日志 ====================
LOG_LEVEL=WARNING
