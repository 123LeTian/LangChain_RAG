# ===================================================================
# LangChain RAG 环境变量配置模板
# ===================================================================
# 使用方法: 复制此文件为 .env 并填入真实值
#   cp .env.dev.example .env
# ===================================================================

# ==================== 1. 模型提供商选择 ====================
# 可选值: deepseek | openai | qwen | glm | moonshot
LLM_PROVIDER=deepseek

# ==================== 2. DeepSeek 配置 ====================
# 仅当 LLM_PROVIDER=deepseek 时生效
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=4096

# ==================== 3. OpenAI 配置 ====================
# 仅当 LLM_PROVIDER=openai 时生效
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ==================== 4. 通义千问 (Qwen) 配置 ====================
# 仅当 LLM_PROVIDER=qwen 时生效
# 通过阿里云 DashScope 或 OpenAI 兼容接口接入
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_NAME=qwen-turbo
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=4096

# ==================== 5. 智谱 GLM 配置 ====================
# 仅当 LLM_PROVIDER=glm 时生效
GLM_API_KEY=your-glm-api-key-here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL_NAME=glm-4-flash
GLM_TEMPERATURE=0.7
GLM_MAX_TOKENS=4096

# ==================== 6. Moonshot (月之暗面) 配置 ====================
# 仅当 LLM_PROVIDER=moonshot 时生效
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL_NAME=moonshot-v1-8k
MOONSHOT_TEMPERATURE=0.7
MOONSHOT_MAX_TOKENS=4096

# ==================== 7. 应用环境 ====================
APP_ENV=dev
LOG_LEVEL=INFO
