# ===================================================================
# LangChain RAG 测试环境配置模板
# ===================================================================
# 使用方法: 复制此文件为 .env.test 并填入真实值
#   cp .env.test.example .env.test
# 然后设置环境变量 APP_ENV=test 启动应用
# ===================================================================

# ==================== 0. 应用环境 ====================
APP_ENV=test

# ==================== 1. 模型提供商选择 ====================
# 可选值: deepseek | openai | qwen | glm | moonshot
LLM_PROVIDER=deepseek

# ==================== 2. DeepSeek 配置 ====================
DEEPSEEK_API_KEY=your-test-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_TEMPERATURE=0.0
DEEPSEEK_MAX_TOKENS=2048

# ==================== 3. OpenAI 配置 (备用) ====================
OPENAI_API_KEY=your-test-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o-mini
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=2048

# ==================== 4. 通义千问 Qwen 配置 (备用) ====================
QWEN_API_KEY=your-test-qwen-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_NAME=qwen-turbo
QWEN_TEMPERATURE=0.0
QWEN_MAX_TOKENS=2048

# ==================== 5. 智谱 GLM 配置 (备用) ====================
GLM_API_KEY=your-test-glm-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL_NAME=glm-4-flash
GLM_TEMPERATURE=0.0
GLM_MAX_TOKENS=2048

# ==================== 6. Moonshot 配置 (备用) ====================
MOONSHOT_API_KEY=your-test-moonshot-key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL_NAME=moonshot-v1-8k
MOONSHOT_TEMPERATURE=0.0
MOONSHOT_MAX_TOKENS=2048

# ==================== 7. 日志 ====================
LOG_LEVEL=DEBUG
